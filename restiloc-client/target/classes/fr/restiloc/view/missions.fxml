<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.HBox?>

<VBox spacing="10" alignment="CENTER" xmlns:fx="http://javafx.com/fxml"
      fx:controller="fr.restiloc.controller.MissionsController" style="-fx-padding: 20;">

    <Label text="Restiloc : Missions du jour" style="-fx-font-size: 18; -fx-font-weight: bold;"/>

    <TableView fx:id="tableMissions" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colHeure" text="Heure" prefWidth="100"/>
            <TableColumn fx:id="colVille" text="Ville" prefWidth="150"/>
            <TableColumn fx:id="colGarage" text="Garage" prefWidth="200"/>
            <TableColumn fx:id="colImmat" text="Immatriculation" prefWidth="150"/>
        </columns>
    </TableView>

    <HBox spacing="10" alignment="CENTER">
        <Button text="Actualiser" onAction="#chargerDonnees"/>
        <Button text="Marquer Indisponible" onAction="#marquerIndisponible" style="-fx-background-color: #e74c3c; -fx-text-fill: white;"/>
    </HBox>
</VBox>